# OpenShift apps domain for this cluster (required before deploy).
# Copy to .env and set your cluster value, then run: ./scripts/configure-cluster.sh
#
# Find it with: oc get ingresscontroller default -n openshift-ingress-operator -o jsonpath='{.status.domain}'
# Example: apps.mycluster.example.com

CLUSTER_APPS_DOMAIN=apps.mycluster.example.com
